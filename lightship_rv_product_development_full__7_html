let activeConceptIdx = 0;

function renderConceptBreakdown() {
  renderAllThreeProfiles();
  renderCACountBars();
  showConcept(0);
}

function renderAllThreeProfiles() {
  const el = document.getElementById('all-three-profiles');
  if (!el) return;
  el.innerHTML = CONCEPT_DETAIL.map((c, idx) => {
    const svg = drawConceptSVG(c.id, 300, 110);
    const loopBg = c.loops === 0 ? '#1c4532' : '#742a2a';
    const loopColor = c.loops === 0 ? '#68d391' : '#fc8181';
    const loopBorder = c.loops === 0 ? '#276749' : '#c53030';
    const loopLabel = c.loops + ' loop' + (c.loops !== 1 ? 's' : '');
    return '<div style="background:#1a202c;border-radius:8px;padding:12px;border:2px solid ' + (c.loops === 0 ? c.color : '#4a5568') + ';cursor:pointer" onclick="showConcept(' + idx + ')">'
      + svg
      + '<div style="display:flex;justify-content:space-between;align-items:center;margin-top:8px">'
      + '<div style="font-family:DM Mono,monospace;font-size:11px;color:' + c.color + ';font-weight:700">' + c.id + ' · ' + c.name + '</div>'
      + '<span style="font-family:DM Mono,monospace;font-size:10px;padding:2px 7px;border-radius:3px;background:' + loopBg + ';color:' + loopColor + ';border:1px solid ' + loopBorder + '">' + loopLabel + '</span>'
      + '</div></div>';
  }).join('');
}

function renderCACountBars() {
  const el = document.getElementById('ca-count-bars');
  if (!el) return;
  const data = [{label:'A · Teardrop',color:'#e53e3e',cas:6,icds:2},{label:'B · Aeroshell',color:'#2f855a',cas:5,icds:2},{label:'C · Active Aero',color:'#c05621',cas:7,icds:3}];
  el.innerHTML = data.map(d => `
    <div style="margin-bottom:14px">
      <div style="display:flex;justify-content:space-between;margin-bottom:4px">
        <span style="font-size:12px;color:${d.color};font-weight:600">${d.label}</span>
        <div style="display:flex;gap:8px">
          <span style="font-family:'DM Mono',monospace;font-size:11px;color:#f7fafc">${d.cas} CAs</span>
          <span style="font-family:'DM Mono',monospace;font-size:11px;color:#fc8181">${d.icds} cross-CA ICDs</span>
        </div>
      </div>
      <div style="background:#1a202c;border-radius:3px;height:12px;overflow:hidden;margin-bottom:3px">
        ${Array(d.cas).fill(0).map((_,i)=>`<div style="display:inline-block;width:calc(${100/d.cas}% - 2px);height:12px;background:${d.color};margin-right:2px;border-radius:2px;opacity:${0.5+0.5*(i<d.icds?0.4:1)}"></div>`).join('')}
      </div>
      <div style="font-size:10px;color:#718096">${d.icds} CA seam${d.icds!==1?'s':''} require active ICD management throughout programme</div>
    </div>`).join('');
}

function showConcept(idx) {
  activeConceptIdx = idx;
  const c = CONCEPT_DETAIL[idx];

  // Update tab buttons
  CONCEPT_DETAIL.forEach(function(cd, i) {
    const btn = document.getElementById('cst-' + i);
    if (!btn) return;
    btn.style.borderBottomColor = i === idx ? cd.color : 'transparent';
    btn.style.background = i === idx ? cd.color + '22' : 'transparent';
    btn.style.color = i === idx ? cd.color : '#718096';
  });

  const area = document.getElementById('concept-detail-area');
  if (!area) return;

  const prosHtml = c.pros.map(function(p) {
    return '<div style="display:flex;gap:7px;margin-bottom:5px;font-size:12px;color:#a0aec0"><span style="color:#68d391;flex-shrink:0">&#10003;</span>' + p + '</div>';
  }).join('');

  const consHtml = c.cons.map(function(p) {
    return '<div style="display:flex;gap:7px;margin-bottom:5px;font-size:12px;color:#a0aec0"><span style="color:#fc8181;flex-shrink:0">&#10007;</span>' + p + '</div>';
  }).join('');

  const subsHtml = c.subsystems.map(function(s) {
    return '<div style="background:#1a202c;border-radius:6px;padding:10px 12px;border-left:3px solid ' + s.color + ';margin-bottom:6px">'
      + '<div style="font-family:DM Mono,monospace;font-size:10px;font-weight:700;color:' + s.color + ';margin-bottom:3px">' + s.name + '</div>'
      + '<div style="font-size:11px;color:#a0aec0;line-height:1.55">' + s.role + '</div>'
      + '</div>';
  }).join('');

  const icdHtml = c.icds.map(function(icd) {
    const bg = icd.severity === 'high' ? 'rgba(197,48,48,.12)' : 'rgba(47,133,90,.1)';
    const border = icd.severity === 'high' ? '#c53030' : '#2f855a';
    const color = icd.severity === 'high' ? '#fc8181' : '#68d391';
    return '<div style="background:' + bg + ';border:1px solid ' + border + ';border-radius:6px;padding:10px 12px;margin-bottom:6px">'
      + '<div style="font-family:DM Mono,monospace;font-size:10px;font-weight:700;color:' + color + ';margin-bottom:3px">' + icd.pair + '</div>'
      + '<div style="font-size:11px;color:#a0aec0;line-height:1.55">' + icd.issue + '</div>'
      + '</div>';
  }).join('');

  const wbsHtml = c.wbsCAs.map(function(ca, i) {
    return '<div style="display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid #2d3748">'
      + '<span style="font-family:DM Mono,monospace;font-size:10px;font-weight:700;color:' + c.color + ';width:28px">' + String.fromCharCode(65 + i) + '</span>'
      + '<span style="font-size:12px;color:#cbd5e0">' + ca + '</span>'
      + '</div>';
  }).join('');

  const loopColor = c.loops === 0 ? '#68d391' : '#fc8181';
  const svgHtml = drawConceptSVG(c.id, 230, 130);

  const leftCol = '<div class="box" style="padding:14px;border-color:' + c.color + '40;background:#1a202c">'
    + '<div style="font-family:DM Mono,monospace;font-size:9px;color:' + c.color + ';font-weight:700;letter-spacing:.15em;text-transform:uppercase;margin-bottom:8px">Profile View</div>'
    + svgHtml
    + '<div style="margin-top:12px">'
    + '<div style="display:flex;justify-content:space-between;margin-bottom:4px"><span style="font-size:11px;color:#718096">Drag (Cd)</span><span style="font-family:DM Mono,monospace;font-size:12px;font-weight:700;color:' + c.color + '">' + c.cdVal + '</span></div>'
    + '<div style="display:flex;justify-content:space-between;margin-bottom:4px"><span style="font-size:11px;color:#718096">Feedback loops</span><span style="font-family:DM Mono,monospace;font-size:12px;font-weight:700;color:' + loopColor + '">' + c.loops + '</span></div>'
    + '<div style="display:flex;justify-content:space-between;margin-bottom:4px"><span style="font-size:11px;color:#718096">WBS CAs</span><span style="font-family:DM Mono,monospace;font-size:12px;font-weight:700;color:#f7fafc">' + c.wbsCAs.length + '</span></div>'
    + '</div>'
    + '<div style="margin-top:12px;padding:8px;background:#0f172a;border-radius:5px;font-size:11px;color:#a0aec0;line-height:1.55;font-style:italic">' + c.tagline + '</div>'
    + '</div>';

  const midCol = '<div>'
    + '<div style="font-family:DM Serif Display,serif;font-size:18px;color:#f7fafc;margin-bottom:4px">Concept ' + c.id + ' \u2014 ' + c.name + '</div>'
    + '<p style="font-size:12px;color:#a0aec0;line-height:1.7;margin-bottom:14px">' + c.philosophy + '</p>'
    + '<div style="font-family:DM Mono,monospace;font-size:10px;color:#718096;letter-spacing:.12em;text-transform:uppercase;margin-bottom:8px">Subsystem anatomy</div>'
    + subsHtml
    + '<div style="font-family:DM Mono,monospace;font-size:10px;color:#718096;letter-spacing:.12em;text-transform:uppercase;margin-top:14px;margin-bottom:8px">Cross-CA interface dependencies</div>'
    + icdHtml
    + '</div>';

  const rightCol = '<div style="display:flex;flex-direction:column;gap:12px">'
    + '<div class="box" style="padding:14px"><div class="eyebrow-sm">WBS Control Accounts</div>' + wbsHtml + '</div>'
    + '<div class="box" style="padding:14px">'
    + '<div style="font-family:DM Mono,monospace;font-size:10px;color:#68d391;font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin-bottom:8px">Advantages</div>'
    + prosHtml
    + '<div style="font-family:DM Mono,monospace;font-size:10px;color:#fc8181;font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin-top:12px;margin-bottom:8px">Trade-offs</div>'
    + consHtml
    + '</div></div>';

  area.innerHTML = '<div style="display:grid;grid-template-columns:260px 1fr 220px;gap:16px;padding-top:18px">'
    + leftCol + midCol + rightCol
    + '</div>';
}

