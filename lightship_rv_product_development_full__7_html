    </div>
  </div>

  <div style="display:grid;grid-template-columns:340px 1fr;gap:18px;align-items:start">
    <!-- Left: tree navigator -->
    <div class="box" style="padding:16px">
      <div class="eyebrow-sm">WBS Navigator</div>
