function showPanel(i) {
  const homeEl = document.getElementById('panel-home');
  if (homeEl) homeEl.classList.remove('active');
  const isLS = typeof i === 'string' && i.startsWith('ls-');
  if (isLS) {
    document.querySelectorAll('.panel').forEach(p => p.classList.toggle('active', p.id === 'panel-' + i));
  } else {
    document.querySelectorAll('.panel').forEach(p => p.classList.toggle('active', parseInt(p.dataset.panelIdx ?? -1) === i));
  }
  const target = isLS ? ("showPanel('" + i + "')") : ('showPanel(' + i + ')');
  document.querySelectorAll('.tab').forEach(t => {
    const fn = t.getAttribute('onclick') || '';
    t.classList.toggle('active', fn === target);
  });
  if (!visitedPanels.has(i)) { visitedPanels.add(i); renderPanel(i); }
  window.scrollTo(0,0);
}

function showHome() {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  const homeEl = document.getElementById('panel-home');
  if (homeEl) homeEl.classList.add('active');
  window.scrollTo(0,0);
}
