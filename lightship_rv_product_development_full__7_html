            <div style="margin-bottom:6px"><span style="color:#718096">Schedule Variance:</span> <span style="color:#f7fafc">SV = EV − PV</span> <span style="color:#4a5568">(negative = behind schedule)</span></div>
            <div style="margin-bottom:6px"><span style="color:#718096">Cost Perf. Index:</span> <span style="color:#f7fafc">CPI = EV ÷ AC</span> <span style="color:#4a5568">(< 1.0 = inefficient spend)</span></div>
            <div><span style="color:#718096">Schedule Perf. Index:</span> <span style="color:#f7fafc">SPI = EV ÷ PV</span> <span style="color:#4a5568">(< 1.0 = behind)</span></div>
