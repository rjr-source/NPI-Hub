        <path d="M0,0 L6,3 L0,6 Z" fill="#4a5568"/>
      </marker>
    </defs>
    ${edges}${nodes}
  </svg>
  <div style="display:flex;gap:16px;margin-top:8px;flex-wrap:wrap">
    <div style="display:flex;align-items:center;gap:5px;font-size:10px;color:#718096"><div style="width:16px;height:2px;background:#fc8181"></div>Critical (0 float)</div>
