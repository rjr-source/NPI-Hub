function verdictColor(v) { return v==="LOW"?"#2f855a":v==="HIGH"?"#c53030":"#c05621"; }

function buildMatrix(concept) {
  const els = concept.elements;
  let h = `<div class="matrix-wrap"><table class="dsm"><thead><tr><td style="width:82px"></td>`;
  els.forEach(e => h += `<th>${e}</th>`);
  h += `</tr></thead><tbody>`;
  concept.matrix.forEach((row, ri) => {
    h += `<tr><td class="row-label">${els[ri]}</td>`;
    row.forEach((cell, ci) => {
      const isDiag=ri===ci, isLoop=cell==="↺", isSeq=cell==="→";
      let cls="cell c-empty", sym="", extra="";
      if (isDiag) { cls="cell c-diag"; sym="▪"; }
      else if (isLoop) { cls="cell c-loop"; sym="↺"; extra=`style="background:${concept.color};border-color:${concept.color}"`; }
      else if (isSeq&&ci>ri) { cls="cell c-seq"; sym="→"; }
      else if (isSeq&&ci<ri) { cls="cell c-down"; sym="↓"; }
      h += `<td class="${cls}" ${extra} title="${isLoop?`Feedback: ${els[ci]} ↺ ${els[ri]}`:isSeq?`${els[ri]} → ${els[ci]}`:""}">${sym}</td>`;
    });
    h += `</tr>`;
  });
  h += `</tbody></table>`;
  h += `<div class="legend">
    <div class="legend-item"><div class="legend-swatch" style="background:#ebf8ff;border:1px solid #2b6cb0;color:#2b6cb0">→</div>Sequential</div>
    <div class="legend-item"><div class="legend-swatch" style="background:${concept.color};color:#fff;font-size:16px">↺</div>Feedback loop</div>
  </div></div>`;
  return h;
}

function buildL2Matrix() {
  const n = L2_ELS.length;
  let h = `<div class="matrix-wrap"><table class="dsm"><thead><tr><td style="width:90px"></td>`;
  L2_ELS.forEach((e,i) => {
    const cl = CLUSTER_COLORS[L2_CLUSTER[i]];
    h += `<th style="color:${cl}">${e}</th>`;
  });
  h += `</tr></thead><tbody>`;
  L2_MATRIX.forEach((row, ri) => {
    const rowCl = CLUSTER_COLORS[L2_CLUSTER[ri]];
    h += `<tr><td class="row-label" style="color:${rowCl}">${L2_ELS[ri]}</td>`;
    row.forEach((cell, ci) => {
      const sameCluster = L2_CLUSTER[ri] === L2_CLUSTER[ci];
      const clColor = CLUSTER_COLORS[L2_CLUSTER[ri]];
      const clBg = CLUSTER_BG[L2_CLUSTER[ri]];
      const isDiag=ri===ci, isSeq=cell==="→", isDown=isSeq&&ci<ri, isUp=isSeq&&ci>ri;
      let cls="cell c-empty", sym="", extra="";
      if (isDiag) {
        cls="cell c-diag c-cluster";
        extra=`style="background:${clBg};border-color:${clColor};color:${clColor}"`;
        sym="▪";
      } else if (isUp && sameCluster) {
        cls="cell c-seq c-cluster";
        extra=`style="background:${clBg};border-color:${clColor}"`;
        sym="→";
      } else if (isDown && sameCluster) {
        cls="cell c-down c-cluster";
        extra=`style="background:${clBg};border-color:${clColor}"`;
        sym="↓";
      } else if (isUp) { cls="cell c-seq"; sym="→"; }
      else if (isDown) { cls="cell c-down"; sym="↓"; }
      h += `<td class="${cls}" ${extra}>${sym}</td>`;
    });
    h += `</tr>`;
  });
  h += `</tbody></table></div>`;
  return h;
}

