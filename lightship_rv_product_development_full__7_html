function renderCPNetwork() {
  const el = document.getElementById('cp-network-diagram');
  if (!el) return;

  // Simple left-to-right swimlane layout
  // Columns by rough start week
  const cols = { A:0, E:0, I:0, J:0,  B:1, D:1, F:1, H:1,  C:2, G:2, K:2,  L:3,  M:4 };
  const rows = { A:0, B:0, C:0, D:1,  E:2, F:2, G:2, H:3,  I:4, J:5, K:5, L:4, M:2 };
  const colX = [60, 200, 340, 480, 600];
  const rowY = [30, 70, 110, 150, 190, 230];
  const pathColor = { critical:'#fc8181', near:'#f6ad55', low:'#718096' };
  const W=660, H=280;

  // Draw edges first
  let edges = '';
  CP_TASKS.forEach(t => {
    t.deps.forEach(dep => {
      const from = CP_TASKS.find(x=>x.id===dep);
      const x1 = colX[cols[dep]]+38, y1 = rowY[rows[dep]]+12;
      const x2 = colX[cols[t.id]]-2, y2 = rowY[rows[t.id]]+12;
      const isCritical = t.path==='critical' && from.path==='critical';
      edges += `<path d="M${x1},${y1} C${(x1+x2)/2},${y1} ${(x1+x2)/2},${y2} ${x2},${y2}"
        fill="none" stroke="${isCritical?'#fc8181':'#4a5568'}" stroke-width="${isCritical?2:1}"
        stroke-dasharray="${isCritical?'none':'4,3'}" marker-end="url(#arr${isCritical?'r':'g'})"/>`;
    });
  });

  // Draw nodes
  let nodes = '';
  CP_TASKS.forEach(t => {
    const x = colX[cols[t.id]], y = rowY[rows[t.id]];
    const col = pathColor[t.path];
    const isCrit = t.path==='critical';
    nodes += `<g>
      <rect x="${x}" y="${y}" width="76" height="24" rx="5"
        fill="${isCrit?'rgba(252,129,129,.15)':t.path==='near'?'rgba(246,173,85,.08)':'rgba(74,85,104,.2)'}"
        stroke="${col}" stroke-width="${isCrit?2:1}"/>
      <text x="${x+38}" y="${y+9}" text-anchor="middle" font-size="8" fill="${col}" font-weight="${isCrit?'700':'400'}">${t.label}</text>
      <text x="${x+38}" y="${y+19}" text-anchor="middle" font-size="7" fill="#718096">${t.dur}w · float:${t.float}d</text>
