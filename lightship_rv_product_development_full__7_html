<!-- ═══════════════════════════════════════════════════════════════════
     LIGHTSHIP L1 — SECTION 11: HOW TO WRITE S.M.A.R.T. REQUIREMENTS
═══════════════════════════════════════════════════════════════════ -->
<div class="panel" id="panel-ls-11">
  <div class="eyebrow-sm" style="margin-bottom:16px">§11 · How to Write S.M.A.R.T. Requirements</div>
  <p class="section-intro">Every requirement in the Lightship L1 PRS and FRS is written to the S.M.A.R.T. standard. A SMART requirement is not merely well-phrased — it is testable, owned, and traceable. No requirement is baselined until it passes the full SMART checklist.</p>

  <!-- Five pillars -->
  <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:24px">
    <div style="background:#1e293b;border-radius:10px;padding:16px;border-top:3px solid #63b3ed;text-align:center">
      <div style="font-family:'DM Mono',monospace;font-size:22px;font-weight:700;color:#63b3ed;margin-bottom:8px">S</div>
      <div style="font-size:12px;font-weight:700;color:#f7fafc;margin-bottom:6px">SPECIFIC</div>
      <div style="font-size:11px;color:#a0aec0;line-height:1.6">One requirement, one behavior. Use <code style="color:#68d391">'shall'</code> for mandatory. No 'and/or' compound statements.</div>
    </div>
    <div style="background:#1e293b;border-radius:10px;padding:16px;border-top:3px solid #68d391;text-align:center">
      <div style="font-family:'DM Mono',monospace;font-size:22px;font-weight:700;color:#68d391;margin-bottom:8px">M</div>
      <div style="font-size:12px;font-weight:700;color:#f7fafc;margin-bottom:6px">MEASURABLE</div>
      <div style="font-size:11px;color:#a0aec0;line-height:1.6">Quantified threshold. No 'adequate', 'sufficient', 'user-friendly'. Every req needs a testable number.</div>
    </div>
    <div style="background:#1e293b;border-radius:10px;padding:16px;border-top:3px solid #f6ad55;text-align:center">
      <div style="font-family:'DM Mono',monospace;font-size:22px;font-weight:700;color:#f6ad55;margin-bottom:8px">A</div>
      <div style="font-size:12px;font-weight:700;color:#f7fafc;margin-bottom:6px">ACHIEVABLE</div>
      <div style="font-size:11px;color:#a0aec0;line-height:1.6">Technically feasible within budget, schedule, and design constraints. Confirmed by responsible engineer.</div>
    </div>
    <div style="background:#1e293b;border-radius:10px;padding:16px;border-top:3px solid #b794f4;text-align:center">
      <div style="font-family:'DM Mono',monospace;font-size:22px;font-weight:700;color:#b794f4;margin-bottom:8px">R</div>
      <div style="font-size:12px;font-weight:700;color:#f7fafc;margin-bottom:6px">RELEVANT</div>
      <div style="font-size:11px;color:#a0aec0;line-height:1.6">Traces to a user story, business objective, or regulatory mandate. No parent = no requirement.</div>
    </div>
    <div style="background:#1e293b;border-radius:10px;padding:16px;border-top:3px solid #fc8181;text-align:center">
      <div style="font-family:'DM Mono',monospace;font-size:22px;font-weight:700;color:#fc8181;margin-bottom:8px">T</div>
      <div style="font-size:12px;font-weight:700;color:#f7fafc;margin-bottom:6px">TESTABLE</div>
      <div style="font-size:11px;color:#a0aec0;line-height:1.6">Verified by T/A/I/D method. Test ID reserved in V&amp;V plan before baselining. Never open-ended.</div>
    </div>
  </div>

  <!-- Good vs Bad examples toggle -->
  <div class="box" style="margin-bottom:20px">
    <div class="eyebrow-sm">Bad vs. Good — Interactive Examples</div>
    <div style="display:flex;gap:8px;margin-bottom:14px" id="smart-tabs">
      <button class="btn btn-sm btn-blue" onclick="showSmartEx('S')">S — Specific</button>
      <button class="btn btn-sm" style="background:#2d3748;color:#a0aec0" onclick="showSmartEx('M')">M — Measurable</button>
      <button class="btn btn-sm" style="background:#2d3748;color:#a0aec0" onclick="showSmartEx('A')">A — Achievable</button>
      <button class="btn btn-sm" style="background:#2d3748;color:#a0aec0" onclick="showSmartEx('R')">R — Relevant</button>
      <button class="btn btn-sm" style="background:#2d3748;color:#a0aec0" onclick="showSmartEx('T')">T — Testable</button>
    </div>
    <div id="smart-ex-content"></div>
  </div>

  <!-- Verification Methods -->
  <div class="eyebrow-sm" style="margin-bottom:12px">Verification Methods — T / A / I / D</div>
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px">
    <div style="background:#1e293b;border-radius:8px;padding:14px">
      <div style="font-family:'DM Mono',monospace;font-size:18px;font-weight:700;color:#63b3ed;margin-bottom:6px">T</div>
      <div style="font-size:11px;font-weight:700;color:#f7fafc;margin-bottom:4px">TEST</div>
      <div style="font-size:10px;color:#a0aec0;line-height:1.6;margin-bottom:8px">Physical measurement under defined conditions. Pass/fail data.</div>
      <div style="font-size:10px;color:#718096;font-style:italic">e.g. Wind tunnel: Cd ≤ 0.30 (VT-001)</div>
    </div>
    <div style="background:#1e293b;border-radius:8px;padding:14px">
      <div style="font-family:'DM Mono',monospace;font-size:18px;font-weight:700;color:#68d391;margin-bottom:6px">A</div>
      <div style="font-size:11px;font-weight:700;color:#f7fafc;margin-bottom:4px">ANALYSIS</div>
      <div style="font-size:10px;color:#a0aec0;line-height:1.6;margin-bottom:8px">Math/simulation using validated models. Used when testing is destructive or impractical.</div>
      <div style="font-size:10px;color:#718096;font-style:italic">e.g. Tongue weight: 10–15% GVWR (FEA)</div>
    </div>
