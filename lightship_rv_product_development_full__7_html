function renderEVMChart() {
  const el = document.getElementById('evm-chart');
  if (!el) return;
  const W = 380, H = 180, PAD = {t:10,r:10,b:30,l:44};
  const cw = W - PAD.l - PAD.r, ch = H - PAD.t - PAD.b;
  const maxVal = 7000, months = 14;
  const xS = m => PAD.l + ((m-1)/(months-1))*cw;
  const yS = v => PAD.t + ch - (v/maxVal)*ch;

  const polyline = (data, key, col) => {
    const pts = data.map(d => `${xS(d.month)},${yS(d[key])}`).join(' ');
    return `<polyline points="${pts}" fill="none" stroke="${col}" stroke-width="2" stroke-linejoin="round"/>`;
  };
  const dots = (data, key, col) => data.map(d =>
    `<circle cx="${xS(d.month)}" cy="${yS(d[key])}" r="3" fill="${col}"/>`).join('');

  // Grid lines
  let grid = '';
  for (let v=0; v<=7000; v+=1000) {
    const y = yS(v);
    grid += `<line x1="${PAD.l}" y1="${y}" x2="${W-PAD.r}" y2="${y}" stroke="#2d3748" stroke-width="1"/>`;
    grid += `<text x="${PAD.l-4}" y="${y+4}" text-anchor="end" font-size="8" fill="#718096">$${v/1000}M</text>`;
  }
  // Month labels
  let xLabels = '';
  for (let m=1; m<=14; m+=2) {
    xLabels += `<text x="${xS(m)}" y="${H-4}" text-anchor="middle" font-size="8" fill="#718096">M${m}</text>`;
  }
  // Today marker at M14
  const todayX = xS(14);
  const todayLine = `<line x1="${todayX}" y1="${PAD.t}" x2="${todayX}" y2="${PAD.t+ch}" stroke="#4a5568" stroke-width="1" stroke-dasharray="3,3"/>
    <text x="${todayX+3}" y="${PAD.t+10}" font-size="8" fill="#718096">today</text>`;

  el.innerHTML = `<svg width="${W}" height="${H}" viewBox="0 0 ${W} ${H}" style="overflow:visible;max-width:100%">
    <style>text{font-family:'DM Mono',monospace}</style>
    ${grid}${xLabels}${todayLine}
    ${polyline(EVM_DATA,'pv','#63b3ed')}
    ${polyline(EVM_DATA,'ac','#f6ad55')}
    ${polyline(EVM_DATA,'ev','#68d391')}
    ${dots(EVM_DATA,'pv','#63b3ed')}
    ${dots(EVM_DATA,'ac','#f6ad55')}
    ${dots(EVM_DATA,'ev','#68d391')}
  </svg>
  <div style="display:flex;gap:14px;margin-top:6px;flex-wrap:wrap">
    <div style="display:flex;align-items:center;gap:5px;font-size:10px;color:#718096"><div style="width:18px;height:3px;background:#63b3ed;border-radius:2px"></div>PV (Plan)</div>
    <div style="display:flex;align-items:center;gap:5px;font-size:10px;color:#718096"><div style="width:18px;height:3px;background:#f6ad55;border-radius:2px"></div>AC (Actual)</div>
    <div style="display:flex;align-items:center;gap:5px;font-size:10px;color:#718096"><div style="width:18px;height:3px;background:#68d391;border-radius:2px"></div>EV (Earned)</div>
  </div>`;
}

function renderEVMKPIs() {
  const el = document.getElementById('evm-kpis');
  if (!el) return;
  const last = EVM_DATA[EVM_DATA.length-1];
  const CV  = last.ev - last.ac;
  const SV  = last.ev - last.pv;
  const CPI = (last.ev / last.ac).toFixed(2);
  const SPI = (last.ev / last.pv).toFixed(2);
  const BAC = 13330;
  const EAC = Math.round(BAC / parseFloat(CPI));
  const kpis = [
    { label:'CPI', val:CPI, good: parseFloat(CPI)>=1, desc:'Cost efficiency' },
    { label:'SPI', val:SPI, good: parseFloat(SPI)>=1, desc:'Schedule efficiency' },
    { label:'CV',  val:(CV<0?'-':'+')+fmt(Math.abs(CV)), good:CV>=0, desc:'Cost variance' },
    { label:'EAC forecast', val:fmt(EAC), good:EAC<=BAC, desc:'Est. at completion' },
  ];
  el.innerHTML = kpis.map(k => `
    <div style="background:#1a202c;border-radius:7px;padding:10px 12px;border-left:3px solid ${k.good?'#2f855a':'#c53030'}">
      <div style="font-family:'DM Mono',monospace;font-size:9px;color:#718096;text-transform:uppercase;letter-spacing:.1em">${k.label}</div>
      <div style="font-family:'DM Mono',monospace;font-size:16px;font-weight:700;color:${k.good?'#68d391':'#fc8181'};margin:3px 0">${k.val}</div>
      <div style="font-size:10px;color:#718096">${k.desc}</div>
    </div>`).join('');
}

function renderWaterfall() {
  const el = document.getElementById('budget-waterfall');
  if (!el) return;
  const caTotal = BUDGET_CA.reduce((s,c)=>s+c.labour+c.materials+c.tooling+c.testing+c.reserve,0);
  const grandTotal = caTotal + BUDGET_MGMT_RESERVE + BUDGET_PROG_CONTINGENCY;
  const bars = [
    ...BUDGET_CA.map(ca => ({ label:ca.ca, val:ca.labour+ca.materials+ca.tooling+ca.testing+ca.reserve, color:ca.color })),
    { label:'Contingency', val:BUDGET_MGMT_RESERVE, color:'#f6ad55' },
    { label:'Mgmt Reserve', val:BUDGET_PROG_CONTINGENCY, color:'#fc8181' },
  ];
  const maxBar = Math.max(...bars.map(b=>b.val));
  el.innerHTML = bars.map(b => {
    const pct = Math.round((b.val/grandTotal)*100);
    const w = Math.round((b.val/maxBar)*100);
    return `<div style="margin-bottom:7px">
      <div style="display:flex;justify-content:space-between;font-family:'DM Mono',monospace;font-size:10px;margin-bottom:3px">
        <span style="color:${b.color}">${b.label}</span>
