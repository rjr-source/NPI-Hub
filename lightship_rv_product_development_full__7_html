<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NPI — DSM → WBS → Requirements</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family:'DM Sans',sans-serif; background:#1a202c; color:#e2e8f0; min-height:100vh; }

/* ── Header ── */
.header { background:linear-gradient(160deg,#2d3748 0%,#1a202c 100%); border-bottom:1px solid #2d3748; padding:28px 40px 20px; }
.header .eyebrow { font-family:'DM Mono',monospace; font-size:10px; color:#63b3ed; letter-spacing:.25em; text-transform:uppercase; margin-bottom:8px; }
.header h1 { font-family:'DM Serif Display',serif; font-size:26px; color:#f7fafc; font-weight:400; letter-spacing:-.01em; line-height:1.15; }
.header p { margin-top:8px; font-size:13px; color:#a0aec0; max-width:640px; line-height:1.7; }

/* ── Progress bar ── */
.progress-bar { display:flex; align-items:center; background:#0f172a; padding:0 40px; border-bottom:1px solid #2d3748; overflow-x:auto; }
.prog-step { display:flex; align-items:center; flex-shrink:0; }
.prog-node { display:flex; flex-direction:column; align-items:center; padding:14px 10px; cursor:pointer; transition:all .18s; position:relative; }
.prog-node:hover .prog-circle { border-color:#63b3ed; }
.prog-circle { width:32px; height:32px; border-radius:50%; border:2px solid #4a5568; background:#1e293b; display:flex; align-items:center; justify-content:center; font-family:'DM Mono',monospace; font-size:11px; font-weight:700; color:#718096; transition:all .2s; }
.prog-circle.done { background:#276749; border-color:#2f855a; color:#fff; }
.prog-circle.active { background:#2b6cb0; border-color:#63b3ed; color:#fff; box-shadow:0 0 0 3px rgba(99,179,237,.2); }
.prog-label { font-size:10px; color:#718096; margin-top:5px; white-space:nowrap; font-weight:500; transition:color .18s; }
.prog-node.active .prog-label { color:#f7fafc; font-weight:600; }
.prog-node.done .prog-label { color:#68d391; }
.prog-arrow { color:#4a5568; font-size:14px; margin:0 2px; padding-top:4px; }

/* ── Tabs ── */
.tabs { display:flex; background:#2d3748; border-bottom:1px solid #4a5568; padding:0 40px; overflow-x:auto; }
.tab { padding:13px 18px; font-size:12px; font-weight:500; color:#a0aec0; border-bottom:3px solid transparent; cursor:pointer; transition:all .18s; user-select:none; white-space:nowrap; }
.tab:hover { color:#e2e8f0; }
.tab.active { color:#f7fafc; border-bottom-color:#63b3ed; font-weight:600; }
.tab-group { display:flex; align-items:center; padding:4px 0; border-right:1px solid #4a5568; margin-right:8px; padding-right:8px; }
.tab-group-label { font-family:'DM Mono',monospace; font-size:9px; color:#4a5568; letter-spacing:.12em; text-transform:uppercase; padding:0 12px; align-self:center; white-space:nowrap; }

/* ── Content ── */
.content { padding:28px 40px; max-width:1100px; margin:0 auto; }
.panel { display:none; animation:fadein .35s ease; }
.panel.active { display:block; }
@keyframes fadein { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }

/* ── Shared boxes ── */
.box { background:#2d3748; border-radius:10px; padding:22px; border:1px solid #4a5568; }
.box-accent { background:#2d3748; border-radius:10px; padding:22px; border-left:3px solid #63b3ed; border-top:1px solid #4a5568; border-right:1px solid #4a5568; border-bottom:1px solid #4a5568; }
.grid2 { display:grid; grid-template-columns:1fr 1fr; gap:18px; margin-bottom:20px; }
.grid3 { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; margin-bottom:20px; }
.eyebrow-sm { font-family:'DM Mono',monospace; font-size:10px; letter-spacing:.18em; text-transform:uppercase; margin-bottom:10px; color:#63b3ed; }
.section-intro { font-size:13px; color:#a0aec0; margin-bottom:20px; line-height:1.7; }

/* ── DSM Matrix ── */
.matrix-wrap { overflow-x:auto; }
table.dsm { border-collapse:collapse; margin:0 auto; font-family:'DM Mono',monospace; }
table.dsm th { width:48px; height:48px; font-size:9px; font-weight:700; color:#718096; writing-mode:vertical-rl; transform:rotate(180deg); vertical-align:bottom; padding-bottom:8px; text-align:center; }
table.dsm td.row-label { font-size:9px; font-weight:700; color:#718096; text-align:right; padding-right:8px; white-space:nowrap; width:82px; }
table.dsm td.cell { width:48px; height:48px; border:1px solid #4a5568; text-align:center; vertical-align:middle; transition:all .15s; }
td.c-diag  { background:#1e293b!important; color:#718096; font-size:10px; }
td.c-seq   { background:#ebf8ff; color:#2b6cb0; font-size:16px; font-weight:700; border-color:#bee3f8!important; }
td.c-down  { background:#fefcbf; color:#744210; font-size:16px; font-weight:700; border-color:#faf089!important; }
td.c-loop  { color:#fff; font-size:20px; font-weight:900; border-width:2px!important; }
td.c-empty { background:#1a2332; }
td.c-cluster { border-width:2px!important; }

/* ── Legend ── */
.legend { display:flex; gap:14px; justify-content:center; margin-top:10px; flex-wrap:wrap; }
.legend-item { display:flex; align-items:center; gap:5px; font-size:10px; color:#718096; }
.legend-swatch { width:20px; height:20px; border-radius:3px; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:13px; font-family:'DM Mono',monospace; flex-shrink:0; }

/* ── Concept cards ── */
.concept-card { background:#2d3748; border-radius:10px; padding:18px; border:2px solid #4a5568; cursor:pointer; transition:transform .2s,box-shadow .2s,opacity .2s; }
.concept-card:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(0,0,0,.4); }
.concept-card.active-card { border-color:var(--concept-color); }
.concept-card.dimmed { opacity:.4; }

/* ── Badge ── */
.badge { font-family:'DM Mono',monospace; font-size:10px; font-weight:700; padding:3px 9px; border-radius:4px; letter-spacing:.08em; }

/* ── Comparison table ── */
.cmp-table { width:100%; border-collapse:collapse; margin-bottom:20px; }
.cmp-table th, .cmp-table td { padding:10px 16px; }
.cmp-table thead th { background:#1a202c; font-family:'DM Mono',monospace; font-size:11px; font-weight:700; letter-spacing:.06em; text-transform:uppercase; border-bottom:1px solid #4a5568; }
.cmp-table td.criterion { font-size:12px; color:#a0aec0; text-align:left; }
.cmp-table td.val { text-align:center; font-family:'DM Mono',monospace; font-size:12px; font-weight:700; }
.val-good { color:#68d391; } .val-bad { color:#fc8181; } .val-mid { color:#f6ad55; }
.col-b td { background:rgba(47,133,90,.1); border-left:1px solid rgba(47,133,90,.25); border-right:1px solid rgba(47,133,90,.25); }
.col-b th { background:rgba(47,133,90,.12); color:#68d391!important; }
tr.even td { background:#2d3748; } tr.odd td { background:#283141; }
tr.even .col-b, tr.odd .col-b { background:rgba(47,133,90,.1)!important; }

/* ── Buttons ── */
.btn { display:inline-block; background:#276749; color:#fff; border:none; padding:11px 30px; border-radius:8px; font-size:13px; font-weight:600; cursor:pointer; font-family:'DM Sans',sans-serif; transition:all .15s; }
.btn:hover { filter:brightness(1.12); transform:translateY(-1px); }
.btn-blue { background:#2b6cb0; }
.btn-amber { background:#b7791f; }
.btn-sm { padding:7px 18px; font-size:12px; }

/* ── Alerts ── */
.green-alert { padding:14px; background:#1c4532; border:1px solid #276749; border-radius:8px; margin-top:14px; }
.blue-alert  { padding:14px; background:#1a365d; border:1px solid #2b6cb0; border-radius:8px; margin-top:14px; }
.amber-alert { padding:14px; background:#2d2007; border:1px solid #b7791f; border-radius:8px; margin-top:14px; }

/* ── WBS task cards ── */
.task-card { background:#1a202c; border-radius:6px; padding:10px 13px; margin-bottom:6px; border-left:3px solid #4a5568; transition:border-color .15s; }
.task-card:hover { border-left-color:#63b3ed; }
.task-id { font-family:'DM Mono',monospace; font-size:10px; font-weight:700; margin-bottom:3px; }
.task-name { font-size:12px; color:#f7fafc; font-weight:600; margin-bottom:3px; }
.task-desc { font-size:11px; color:#a0aec0; line-height:1.55; margin-bottom:5px; }
.task-meta { display:flex; gap:8px; flex-wrap:wrap; }
.task-tag { font-family:'DM Mono',monospace; font-size:9px; padding:2px 7px; border-radius:3px; font-weight:700; }
.tag-deliverable { background:#1a365d; color:#90cdf4; border:1px solid #2b6cb0; }
.tag-gate { background:#2d2007; color:#f6ad55; border:1px solid #b7791f; }
.tag-owner { background:#1c4532; color:#68d391; border:1px solid #276749; }
.tag-duration { background:#2d3748; color:#a0aec0; border:1px solid #4a5568; }
.wp-header { background:#2d3748; border-radius:8px; padding:14px 16px; margin-bottom:14px; border-left:4px solid #63b3ed; }
.wp-header-title { font-family:'DM Serif Display',serif; font-size:17px; color:#f7fafc; margin-bottom:4px; }
.wp-header-meta { display:flex; gap:10px; flex-wrap:wrap; font-size:11px; color:#718096; }

/* ── WBS tree ── */
.wbs-tree { font-family:'DM Mono',monospace; font-size:12px; line-height:2; }
.wbs-l0 { color:#f7fafc; font-size:13px; font-weight:700; padding:4px 0; }
.wbs-l1 { color:#63b3ed; padding-left:16px; font-weight:700; cursor:pointer; line-height:1.8; display:flex; align-items:center; gap:4px; }
.wbs-l1:hover { color:#90cdf4; }
.wbs-l2-item { padding-left:32px; line-height:1.8; display:flex; align-items:center; gap:4px; cursor:pointer; transition:color .15s; }
.wbs-l2-item:hover .wbs-l2-name { text-decoration:underline; }
.wbs-l2-name { font-size:11px; }
.wbs-l2-item.selected .wbs-l2-name { font-weight:700; }
.wbs-ca { display:inline-block; font-size:9px; padding:1px 6px; border-radius:3px; margin-left:6px; vertical-align:middle; font-weight:700; letter-spacing:.04em; }
.wbs-toggle { color:#4a5568; transition:transform .2s; display:inline-block; font-size:10px; width:12px; flex-shrink:0; }
.wbs-children { overflow:hidden; transition:max-height .3s ease; }

/* ── RTM rows ── */
.rtm-row { display:grid; grid-template-columns:90px 1fr 1fr 80px; gap:0; border-bottom:1px solid #2d3748; transition:background .15s; }
.rtm-row:hover { background:#2d3748; }
.rtm-cell { padding:10px 12px; font-size:12px; border-right:1px solid #2d3748; }
.rtm-cell:last-child { border-right:none; }
.rtm-status { display:inline-block; font-family:'DM Mono',monospace; font-size:10px; font-weight:700; padding:2px 8px; border-radius:3px; }
.status-open   { background:#2d2007; color:#f6ad55; border:1px solid #b7791f; }
.status-linked { background:#1a365d; color:#63b3ed; border:1px solid #2b6cb0; }
.status-tested { background:#1c4532; color:#68d391; border:1px solid #276749; }
.status-closed { background:#276749; color:#fff; }

/* ── Flow arrows / connectors ── */
.flow-chain { display:flex; align-items:center; gap:0; margin-bottom:20px; flex-wrap:wrap; }
.flow-box { background:#2d3748; border:2px solid #4a5568; border-radius:8px; padding:12px 16px; text-align:center; min-width:110px; transition:border-color .2s; }
.flow-box.active { border-color:#63b3ed; background:#1a3a5c; }
.flow-box.done { border-color:#2f855a; background:#1c4532; }
.flow-box-label { font-size:11px; font-weight:600; color:#f7fafc; }
.flow-box-sub { font-size:10px; color:#718096; margin-top:3px; }
.flow-connector { font-size:20px; color:#4a5568; padding:0 6px; flex-shrink:0; }

/* ── Cluster highlight colours ── */
.cl-aero  { background:rgba(49,130,206,.15); border-color:#3182ce!important; }
.cl-power { background:rgba(221,107,32,.15); border-color:#dd6b20!important; }
.cl-gear  { background:rgba(56,161,105,.15); border-color:#38a169!important; }
.cl-sw    { background:rgba(159,122,234,.15); border-color:#9f7aea!important; }

/* ── Req cards ── */
.req-card { background:#1e293b; border-radius:8px; padding:14px 16px; border-left:3px solid #4a5568; margin-bottom:8px; transition:border-color .2s; }
.req-card.prs { border-left-color:#3182ce; }
.req-card.frs { border-left-color:#dd6b20; }
.req-id { font-family:'DM Mono',monospace; font-size:10px; font-weight:700; margin-bottom:4px; }
.req-text { font-size:12px; color:#cbd5e0; line-height:1.55; }
.req-trace { font-size:10px; color:#718096; margin-top:5px; font-family:'DM Mono',monospace; }

/* ── Misc ── */
.center { text-align:center; margin-top:20px; }
.mt12 { margin-top:12px; } .mt16 { margin-top:16px; } .mt20 { margin-top:20px; } .mt24 { margin-top:24px; }
.flex-row { display:flex; gap:32px; align-items:flex-start; flex-wrap:wrap; }
.flex-col { display:flex; flex-direction:column; gap:12px; }
.icon-box { width:48px; height:48px; background:#2f855a; border-radius:9px; display:flex; align-items:center; justify-content:center; font-size:24px; flex-shrink:0; }
.detail-box { background:#2d3748; border-radius:10px; padding:24px; border:2px solid #4a5568; margin-top:0; animation:fadein .3s ease; }
.red-label { font-family:'DM Mono',monospace; font-size:10px; color:#fc8181; font-weight:700; letter-spacing:.12em; text-transform:uppercase; margin-bottom:10px; }
.loop-item { display:flex; gap:10px; margin-bottom:8px; align-items:flex-start; }
.loop-sym { font-size:18px; font-family:'DM Mono',monospace; line-height:1; flex-shrink:0; }
.loop-text { font-size:12px; color:#cbd5e0; line-height:1.6; }
.insight { padding:12px; background:#1a202c; border-radius:8px; border:1px solid #2c5282; }
.insight .label { color:#63b3ed; font-weight:600; font-size:11px; margin-bottom:4px; }
.insight p { color:#a0aec0; font-size:11px; line-height:1.65; }
.step-counter { display:inline-flex; align-items:center; justify-content:center; width:24px; height:24px; border-radius:50%; background:#2b6cb0; color:#fff; font-size:11px; font-weight:700; font-family:'DM Mono',monospace; flex-shrink:0; }

@media(max-width:720px) {
  .grid2,.grid3 { grid-template-columns:1fr; }
  .content { padding:16px; }
  .header { padding:18px 16px; }
  .tabs { padding:0 8px; }
  .progress-bar { padding:0 8px; }
  .flex-row { flex-direction:column; gap:16px; }
  .rtm-row { grid-template-columns:70px 1fr; }
  .rtm-cell:nth-child(3),.rtm-cell:nth-child(4) { display:none; }
}

/* ─── Search bar ─────────────────────────────────────────── */
.search-bar-wrap {
  display:flex; align-items:center; gap:12px;
  padding:10px 40px; background:#111827;
  border-bottom:1px solid #1f2937;
}
.search-trigger {
  display:flex; align-items:center; gap:10px;
  flex:1; max-width:480px;
  background:#1f2937; border:1px solid #374151;
  border-radius:8px; padding:9px 14px;
  cursor:text; transition:border-color .18s;
  color:#6b7280; font-size:13px;
  font-family:'DM Sans',sans-serif;
}
.search-trigger:hover { border-color:#4b5563; color:#9ca3af; }
.search-trigger svg { flex-shrink:0; }
.search-trigger-text { flex:1; }
.search-kbd {
  font-family:'DM Mono',monospace; font-size:10px;
  color:#4b5563; border:1px solid #374151;
  border-radius:4px; padding:2px 7px;
}
.home-btn {
  background:#1f2937; border:1px solid #374151;
  border-radius:8px; padding:9px 16px;
  color:#9ca3af; font-family:'DM Sans',sans-serif;
  font-size:12px; font-weight:500; cursor:pointer;
  transition:all .18s; white-space:nowrap; display:flex;
  align-items:center; gap:6px;
}
.home-btn:hover { background:#374151; color:#f9fafb; border-color:#4b5563; }

/* ─── Search overlay ─────────────────────────────────────── */
.search-overlay {
  position:fixed; inset:0; z-index:9000;
  background:rgba(0,0,0,.75); backdrop-filter:blur(4px);
  display:flex; align-items:flex-start; justify-content:center;
  padding-top:72px; opacity:0; pointer-events:none;
  transition:opacity .18s;
}
.search-overlay.open { opacity:1; pointer-events:all; }
.search-modal {
  background:#1f2937; border:1px solid #374151;
  border-radius:14px; width:640px; max-width:92vw;
  max-height:72vh; display:flex; flex-direction:column;
  box-shadow:0 32px 80px rgba(0,0,0,.7);
  transform:translateY(-8px); transition:transform .18s;
}
.search-overlay.open .search-modal { transform:translateY(0); }
.search-modal-header {
  display:flex; align-items:center; gap:12px;
  padding:16px 18px; border-bottom:1px solid #374151;
}
.search-modal-input {
  flex:1; background:transparent; border:none; outline:none;
  color:#f9fafb; font-family:'DM Sans',sans-serif;
  font-size:15px;
}
.search-modal-input::placeholder { color:#4b5563; }
.search-close-btn {
  background:none; border:1px solid #374151;
  border-radius:6px; color:#6b7280; padding:4px 10px;
  font-size:12px; cursor:pointer; transition:all .15s;
  font-family:'DM Mono',monospace;
}
.search-close-btn:hover { background:#374151; color:#f9fafb; }
.search-results-list { overflow-y:auto; padding:6px; }
.search-result {
  padding:12px 14px; border-radius:8px; cursor:pointer;
  transition:background .12s; border-bottom:1px solid #111827;
}
.search-result:hover, .search-result:focus { background:#374151; outline:none; }
.search-result-tag {
  font-family:'DM Mono',monospace; font-size:9px;
  letter-spacing:.15em; text-transform:uppercase;
  color:#60a5fa; margin-bottom:3px;
}
.search-result-title { font-size:13px; font-weight:600; color:#f9fafb; margin-bottom:3px; }
.search-result-snippet { font-size:11px; color:#9ca3af; line-height:1.5; }
mark { background:#1d4ed844; color:#93c5fd; border-radius:2px; padding:0 1px; }
.search-empty {
  padding:40px 20px; text-align:center;
  color:#6b7280; font-size:13px; line-height:1.7;
}
.search-footer {
  padding:10px 16px; border-top:1px solid #374151;
  display:flex; gap:14px; font-family:'DM Mono',monospace;
  font-size:10px; color:#4b5563;
}
.search-footer span b { color:#6b7280; }

/* ─── Home / landing panel ───────────────────────────────── */
.home-panel { display:none; animation:fadein .3s ease; }
.home-panel.active { display:block; }

.home-hero {
  margin-bottom:32px;
}
.home-hero-eyebrow {
  font-family:'DM Mono',monospace; font-size:10px;
  letter-spacing:.25em; text-transform:uppercase;
  color:#60a5fa; margin-bottom:12px;
}
.home-hero h2 {
  font-family:'DM Serif Display',serif;
  font-size:30px; font-weight:400; color:#f9fafb;
  line-height:1.2; margin-bottom:12px;
}
.home-hero p {
  font-size:13px; color:#9ca3af; max-width:680px; line-height:1.8;
}

.home-stats {
  display:grid; grid-template-columns:repeat(6,1fr);
  gap:10px; margin-bottom:36px;
}
.stat-tile {
  background:#1f2937; border:1px solid #374151;
  border-radius:10px; padding:16px 12px; text-align:center;
}
.stat-num {
  font-family:'DM Mono',monospace; font-size:19px;
  font-weight:700; margin-bottom:4px;
}
.stat-label {
  font-size:9px; color:#6b7280; text-transform:uppercase;
  letter-spacing:.12em; line-height:1.4;
}

/* ─── Phase flow ─────────────────────────────────────────── */
.phase-flow { display:flex; flex-direction:column; gap:0; max-width:860px; margin:0 auto; }

.gate-row {
  display:flex; align-items:center; gap:14px;
  padding:6px 0 6px 20px;
}
.gate-pip {
  width:36px; height:36px; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-family:'DM Mono',monospace; font-size:10px;
  font-weight:700; flex-shrink:0; cursor:default;
  box-shadow:0 0 0 4px #111827, 0 0 0 5px var(--gc);
  background:var(--gc); color:#111827;
}
.gate-label { font-size:11px; color:#6b7280; font-style:italic; }
.gate-line { flex:1; height:1px; background:#1f2937; }
.connector { width:2px; background:#1f2937; height:20px; margin-left:37px; }

.phase-card {
  background:#1f2937; border:1px solid #374151;
  border-radius:12px; padding:20px 22px;
  cursor:pointer; transition:all .2s;
  border-left:3px solid var(--pc);
  position:relative; overflow:hidden;
}
.phase-card::after {
  content:''; position:absolute; inset:0;
  background:radial-gradient(ellipse at top left, var(--pc)08, transparent 60%);
  pointer-events:none;
}
.phase-card:hover {
  border-color:var(--pc);
  box-shadow:0 6px 24px rgba(0,0,0,.4), 0 0 0 1px var(--pc)33;
  transform:translateY(-1px);
}
.phase-card-header {
  display:flex; align-items:center; gap:12px; margin-bottom:12px;
}
.phase-badge {
  font-family:'DM Mono',monospace; font-size:10px; font-weight:700;
  padding:3px 10px; border-radius:5px;
  background:var(--pc)18; color:var(--pc);
