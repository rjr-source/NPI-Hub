function renderConceptSelection() {
  renderSelTable();
  renderConceptWBSCompare();
}

function renderSelTable() {
  const tbody = document.getElementById('sel-tbody');
  if (!tbody || tbody.innerHTML.trim()) return;
  tbody.innerHTML = CMP_ROWS.map((row,ri) => `<tr class="${ri%2===0?'even':'odd'}">
    <td class="criterion">${row[0]}</td>
    <td class="val ${row[1].includes('✓')?'val-good':row[1].includes('✗')?'val-bad':'val-mid'}">${row[1]}</td>
    <td class="val col-b ${row[2].includes('✓')?'val-good':row[2].includes('✗')?'val-bad':'val-mid'}">${row[2]}</td>
    <td class="val ${row[3].includes('✓')?'val-good':row[3].includes('✗')?'val-bad':'val-mid'}">${row[3]}</td>
  </tr>`).join('');
}

function renderConceptWBSCompare() {
  const el = document.getElementById('concept-wbs-compare');
  if (!el || el.innerHTML.trim()) return;
  el.innerHTML = CONCEPT_DETAIL.map(c => {
    const isSelected = c.id === 'B';
    return `<div style="background:#1a202c;border-radius:8px;padding:14px;border:2px solid ${isSelected?c.color:'#4a5568'}">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
        <div style="font-family:'DM Mono',monospace;font-size:11px;color:${c.color};font-weight:700">Concept ${c.id}</div>
        ${isSelected?`<span style="font-family:'DM Mono',monospace;font-size:9px;background:#276749;color:#fff;padding:2px 7px;border-radius:3px">SELECTED</span>`:''}
      </div>
      <div style="font-size:12px;color:#f7fafc;font-weight:600;margin-bottom:8px">${c.name}</div>
      <div style="font-size:10px;color:#718096;margin-bottom:6px;font-family:'DM Mono',monospace;text-transform:uppercase;letter-spacing:.08em">${c.wbsCAs.length} control accounts:</div>
      ${c.wbsCAs.map((ca,i)=>`<div style="display:flex;align-items:center;gap:6px;padding:3px 0">
        <div style="width:8px;height:8px;border-radius:50%;background:${c.color};opacity:${isSelected?1:0.5};flex-shrink:0"></div>
