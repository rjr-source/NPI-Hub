      <div style="text-align:center">
        <div class="rtm-status status-open" style="font-size:11px;padding:4px 12px">OPEN</div>
        <div style="font-size:10px;color:#718096;margin-top:4px">PRS written</div>
      </div>
      <div style="color:#4a5568;font-size:18px">→</div>
      <div style="text-align:center">
        <div class="rtm-status status-linked" style="font-size:11px;padding:4px 12px">LINKED</div>
        <div style="font-size:10px;color:#718096;margin-top:4px">FRS allocated</div>
      </div>
      <div style="color:#4a5568;font-size:18px">→</div>
      <div style="text-align:center">
        <div class="rtm-status status-tested" style="font-size:11px;padding:4px 12px">TESTED</div>
        <div style="font-size:10px;color:#718096;margin-top:4px">Test case assigned</div>
      </div>
      <div style="color:#4a5568;font-size:18px">→</div>
