function hl(text, q) {
  if (!q) return text;
  return text.replace(new RegExp(q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&'),'gi'), m => `<mark>${m}</mark>`);
}

function snippet(text, q) {
  const i = text.toLowerCase().indexOf(q.toLowerCase());
  if (i < 0) return text.slice(0,110)+'…';
  const s = Math.max(0,i-45), e = Math.min(text.length,i+q.length+70);
  return (s?'…':'')+text.slice(s,e)+(e<text.length?'…':'');
}

function runSearch(q) {
  const list = document.getElementById('search-results');
  if (!list) return;
  const raw = q.trim();
  if (!raw) {
    list.innerHTML = '<div class="search-empty">Start typing to search all 33 sections,<br>requirements, metrics, and topics.</div>';
    return;
  }
  const words = raw.toLowerCase().split(/\s+/).filter(Boolean);
  const hits = SEARCH_INDEX.map(item => {
    const hay = (item.s+' '+item.t).toLowerCase();
    const score = words.reduce((a,w)=>a+(hay.split(w).length-1),0);
    return {...item, score};
  }).filter(r=>r.score>0).sort((a,b)=>b.score-a.score).slice(0,10);

  if (!hits.length) {
    list.innerHTML = `<div class="search-empty">No results for <strong style="color:#f9fafb">"${raw}"</strong><br>Try different keywords.</div>`;
    return;
  }
  list.innerHTML = hits.map(r => `<div class="search-result" tabindex="0" onclick="closeSearch();showPanel(${r.p})">
    <div class="search-result-tag">${r.s}</div>
    <div class="search-result-title">${hl(r.s,raw)}</div>
    <div class="search-result-snippet">${hl(snippet(r.t,words[0]),raw)}</div>
  </div>`).join('');
}

function openSearch() {
  const ov = document.getElementById('search-overlay');
  if (!ov) return;
  ov.classList.add('open');
  setTimeout(()=>{
    const inp = document.getElementById('search-input');
    if (inp){ inp.value=''; inp.focus(); runSearch(''); }
  },60);
}

function closeSearch() {
  const ov = document.getElementById('search-overlay');
  if (ov) ov.classList.remove('open');
}

document.addEventListener('keydown', e => {
  if ((e.key==='/' || e.key==='k' && (e.metaKey||e.ctrlKey)) &&
      !['INPUT','TEXTAREA'].includes(document.activeElement.tagName)) {
    e.preventDefault(); openSearch(); return;
  }
  if (e.key==='Escape') { closeSearch(); return; }
  const ov = document.getElementById('search-overlay');
  if (!ov?.classList.contains('open')) return;
  const items = [...document.querySelectorAll('.search-result')];
  const fi = document.activeElement;
  const idx = items.indexOf(fi);
  if (e.key==='ArrowDown') { e.preventDefault(); (items[idx+1]||items[0])?.focus(); }
  if (e.key==='ArrowUp')   { e.preventDefault(); idx>0 ? items[idx-1].focus() : document.getElementById('search-input')?.focus(); }
  if (e.key==='Enter' && idx>=0) { fi.click(); }
});

