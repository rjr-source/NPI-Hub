<!-- ═══════════════════════════════════════════════════════════
     PANEL 3 — WBS
═══════════════════════════════════════════════════════════ -->
<div class="panel" id="panel-4" data-panel-idx="4">
  <p class="section-intro">The WBS decomposes the scope of the chosen architecture into four levels: <strong style="color:#f7fafc">Programme → Control Account → Work Package → Tasks</strong>. Every CA boundary follows a DSM cluster boundary. Click any work package to expand its individual tasks.</p>

  <!-- Top stat bar -->
  <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:20px" id="wbs-stats">
